# ============================================================
# API 性能测试配置文件（通过 k6 -e 传入或 export 环境变量）
# ============================================================

# ---------- 目标接口 ----------
# 接口名称（用于报告展示）
API_NAME=示例接口

# 目标服务基础地址
BASE_URL=http://localhost:8080

# 请求路径（支持路径参数占位符）
API_PATH=/api/v1/example

# 请求方法：GET | POST | PUT | DELETE
METHOD=GET

# ---------- 请求参数 ----------
# Query 参数（JSON 格式，会拼接到 URL）
QUERY_PARAMS={"page": 0, "size": 30}

# 请求体（仅 POST/PUT 有效，JSON 字符串）
# BODY={"key": "value"}

# 自定义请求头（JSON 格式，会与默认 headers 合并）
# CUSTOM_HEADERS={"X-Custom-Header": "value"}

# ---------- 认证 ----------
# Bearer Token（可选）
# TOKEN=your-jwt-token

# Cookie（可选）
# COOKIE=session_id=abc123

# ---------- 响应校验 ----------
# 期望的 HTTP 状态码（默认 200）
EXPECTED_STATUS=200

# 响应 JSON 中需要非空校验的字段路径（可选，如 "data" 或 "data.list"）
CHECK_FIELD=data

# ---------- 性能阈值 ----------
# p95 响应时间上限（毫秒）
THRESHOLD_P95=500

# p99 响应时间上限（毫秒）
THRESHOLD_P99=1000

# 最大错误率（百分比，如 1 表示 1%）
THRESHOLD_ERROR_RATE=1
