# POST 接口压测配置示例
# 适用于需要提交 JSON Body 的接口

API_NAME=用户搜索接口
BASE_URL=https://api.example.com
API_PATH=/api/v1/users/search
METHOD=POST
BODY={"keyword": "test", "page": 1, "pageSize": 20}
CUSTOM_HEADERS={"X-Request-Source": "perf-test"}
EXPECTED_STATUS=200
CHECK_FIELD=data.list
THRESHOLD_P95=300
THRESHOLD_P99=800
THRESHOLD_ERROR_RATE=1
# TOKEN=your-jwt-token
