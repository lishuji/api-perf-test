# Cloud Studio 热门排行榜接口测试配置
# 用法: 将以下参数通过 k6 -e 逐一传入，或 export 后运行

API_NAME=Cloud Studio 热门排行榜
BASE_URL=https://cloudstudio.net
API_PATH=/api/liteapps/rankings/hot
METHOD=GET
QUERY_PARAMS={"timestamp": "1713100000", "page": "0", "size": "30"}
EXPECTED_STATUS=200
CHECK_FIELD=data
THRESHOLD_P95=500
THRESHOLD_P99=1000
THRESHOLD_ERROR_RATE=1
# TOKEN=your-jwt-token
