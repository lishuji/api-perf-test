{
  "global": {
    "baseUrl": "http://localhost:8080",
    "thresholds": { "p95": 500, "p99": 1000, "errorRate": 1 }
  },

  "apis": {
    "user-list": {
      "name": "用户列表",
      "path": "/api/v1/users",
      "method": "GET",
      "query": { "page": 1, "size": 20 },
      "checkField": "data.list"
    },

    "user-search": {
      "name": "用户搜索",
      "path": "/api/v1/users/search",
      "method": "POST",
      "body": { "keyword": "test", "page": 1, "pageSize": 20 },
      "checkField": "data.list",
      "thresholds": { "p95": 300 }
    }
  }
}
